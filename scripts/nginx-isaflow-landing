# IsaFlow — Landing + App (isaflow.co.za + app.isaflow.co.za)
# Both domains serve from the same Next.js app on port 3101
# Landing page at /, login at /login, app at /accounting/*
# Cloudflare SSL: Flexible (CF terminates SSL, connects to origin on HTTP)
server {
    listen 80;
    server_name isaflow.co.za www.isaflow.co.za app.isaflow.co.za;

    client_max_body_size 50M;

    location / {
        proxy_pass http://localhost:3101;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
