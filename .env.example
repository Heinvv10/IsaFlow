# Accounting App - Environment Variables
# Copy to .env.local and fill in real values

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# Environment
NODE_ENV=development

# Public app URL
NEXT_PUBLIC_APP_URL=http://localhost:3101

# PayFast Payment Gateway (sandbox defaults)
PAYFAST_MERCHANT_ID=YOUR_PAYFAST_MERCHANT_ID
PAYFAST_MERCHANT_KEY=YOUR_PAYFAST_MERCHANT_KEY
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# SMTP (email sending)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@isaflow.co.za

# Bank Feeds (Stitch / Investec Open Banking)
STITCH_CLIENT_ID=your-stitch-client-id
STITCH_CLIENT_SECRET=your-stitch-client-secret
STITCH_REDIRECT_URI=http://localhost:3101/api/accounting/bank-feeds/callback

# Admin seed password (used by db:migrate)
ADMIN_PASSWORD=change-me-in-production

# Neon driver transport (set to 'true' to force HTTP instead of WebSocket)
NEON_USE_HTTP=false

# E2E test credentials
E2E_ADMIN_EMAIL=admin@accounting.local
E2E_ADMIN_PASSWORD=admin123
